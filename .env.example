# Default: use a local SQLite database in ./instance/pullan_dental_local.db
USE_LOCAL_SQLITE=true

# Local network server settings used by python app.py / start_lan.bat
APP_HOST=0.0.0.0
APP_PORT=5000
FLASK_DEBUG=true

# Optional PostgreSQL settings if you want to use PostgreSQL again later.
# USE_LOCAL_SQLITE=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pullandental
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# Or use a full SQLAlchemy database URI.
# DATABASE_URL=postgresql://user:password@localhost:5432/pullandental

# SMS reminders. Use console for testing; use movider, twilio, or semaphore for real sending.
SMS_PROVIDER=console
SMS_REMINDER_WORKER=true
SMS_WORKER_INTERVAL_SECONDS=60
SMS_SENDER_NAME=PullanDental
CLINIC_NAME=Pullan Dental Clinic
SMS_HTTP_USER_AGENT=curl/8.4.0

# Movider provider settings.
# Movider requires both API key and API secret from Settings > API Settings.
# MOVIDER_API_KEY=your_api_key
# MOVIDER_API_SECRET=your_api_secret

# Twilio provider settings. Philippines sender IDs may require registration.
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=your_registered_sender_or_number

# Semaphore provider settings for Philippine SMS.
# SEMAPHORE_API_KEY=your_api_key
# SEMAPHORE_SENDER_NAME=PullanDental
