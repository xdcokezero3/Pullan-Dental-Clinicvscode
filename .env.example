# Default: use a local SQLite database in ./instance/pullan_dental_local.db
USE_LOCAL_SQLITE=true

# Local server settings used by python app.py and the desktop shortcut.
APP_HOST=127.0.0.1
APP_PORT=5000
FLASK_DEBUG=true

# Optional PostgreSQL settings if you want to use PostgreSQL again later.
# USE_LOCAL_SQLITE=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pullandental
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# Or use a full SQLAlchemy database URI.
# DATABASE_URL=postgresql://user:password@localhost:5432/pullandental

# SMS reminders. Use console for testing; use twilio for real sending.
SMS_PROVIDER=twilio
SMS_REMINDER_WORKER=true
SMS_WORKER_INTERVAL_SECONDS=60
SMS_SENDER_NAME=PullanDental
CLINIC_NAME=Pullan Dental Clinic
SMS_HTTP_USER_AGENT=curl/8.4.0

# Twilio provider settings.
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# Use a Messaging Service SID after registering/approving a sender for Philippine SMS.
# TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid
# TWILIO_FROM_NUMBER=+12566703250

# Semaphore provider settings for Philippine SMS.
# SEMAPHORE_API_KEY=your_api_key
# SEMAPHORE_SENDER_NAME=PullanDental
